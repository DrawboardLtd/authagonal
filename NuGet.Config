<?xml version="1.0" encoding="utf-8"?>
<!--
  CI feeds just-built Authagonal.* packages into ./nupkgs so demo Dockerfiles can
  restore them immediately, without waiting for nuget.org's v3-flatcontainer to
  index a fresh push (typically 4–6 min). Locally the directory is empty/absent
  and NuGet falls through to nuget.org as normal.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="local-nupkgs" value="./nupkgs" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
